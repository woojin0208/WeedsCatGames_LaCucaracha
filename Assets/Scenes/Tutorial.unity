  m_Script: {fileID: 11500000, guid: bbac3b06032915149891c635aff99ffb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textPosition: {fileID: 818160289}
  dialogueNodeData: []
  nodeEvents: []
  optionEvents: []
  <NPCId>k__BackingField: 7
  <InteractivePos>k__BackingField: {fileID: 0}
  entry: {fileID: 0}
  npcAnimator: {fileID: 0}
  enemyBase: {fileID: 380837306}
  tutorialText: {fileID: 1229129157}
  textIndex: {fileID: 598862469}
  speakerRenderer: {fileID: 1626216693}
  tutorialTexts:
  - "\uB9C8\uC6B0\uC2A4 \uC88C\uD074\uB9AD\uC73C\uB85C \uB2ED\uC744 \uACF5\uACA9\uD558\uC5EC
    \uBC29\uC1A1\uC744 \uD655\uC778\uD558\uC2ED\uC2DC\uC624."
  - "\uAE08\uC77C WASD\uB85C \uC6B0\uCE21 \uAC00\uC2DC\uB85C \uB300\uD53C \uBC14\uB78C\n\uC7AC\uB09C
    \uBC29\uC1A1\uC5D0 \uADC0 \uAE30\uC6B8\uC5EC\uC8FC\uC2DC\uAE38 \uBC14\uB78D\uB2C8\uB2E4."
  - "\uBA40\uB9AC\uC11C \uB9C8\uC6B0\uC2A4 \uC6B0\uD074\uB9AD\uC744 \uC0AC\uC6A9\uD574
    \uC544\uC774\uD15C\uC744 \n\uB358\uC838 \uD655\uC778\uD558\uC5EC \uC8FC\uC2DC\uAE30
    \uBC14\uB78D\uB2C8\uB2E4."
  - "\uC88C\uCE21 \uB178\uB780\uC0C9 \uC7A5\uCE58\uB97C E\uD0A4\uC640 \uB9C8\uC6B0\uC2A4\uB85C
    \n\uC870\uC791\uD558\uC5EC \uC790\uC138\uD55C \uD589\uB3D9 \uC694\uB839\uC744
    \uD655\uC778\uD558\uC2ED\uC2DC\uC624."
  - "[\uD589\uBCF5 \uD2B9\uBCC4\uC2DC] \n\uC624\uB298 13\uC2DC \uB3D9\uB0A8\uCABD
    \uBC29\uBCBD, \nSpace Bar\uB97C \uB450 \uBC88 \uB20C\uB7EC \n\uB354\uBE14\uC810\uD504\uD558\uB294
    \uB3CC\uC5F0\uBCC0\uC774\uAC00 \uD0C8\uCD9C. \n\uC8FC\uC758 \uBC14\uB78D\uB2C8\uB2E4."
  - "\uD574\uB2F9 \uAC1C\uCCB4\uB294 Shift\uB97C \uB20C\uB7EC \uB300\uC2DC\uB97C
    \uC0AC\uC6A9.\n\uBA3C \uAC70\uB9AC\uB3C4 \uBE60\uB974\uAC8C \uB2E4\uAC00\uC62C
    \uC218 \uC788\uAE30\uC5D0 \n\uC548\uC804 \uAC70\uB9AC\uC5D0 \uC720\uC758\uD558\uC2ED\uC2DC\uC624."
  guardText: "\uBAA8\uB4E0 \uC7AC\uB09C \uBC29\uC1A1\uC744 \uD655\uC778\uD558\uAE30
    \uC804\uC5D0\uB294 \n\uC808 \uB300 \uB85C \uC123\uBD88\uB9AC \uD589\uB3D9\uD560
    \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
